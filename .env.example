TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here
NEXT_PUBLIC_NEAR_WALLET_NETWORK=testnet

# IronClaw TEE (NEAR AI Cloud)
# https://cloud.near.ai/ 에서 API Key 발급
IRONCLAW_BASE_URL=https://cloud-api.near.ai/v1
IRONCLAW_API_KEY=your-nearai-api-key-here
# 기본값: Qwen/Qwen3-30B-A3B-Instruct-2507 (생략 가능)
# 사용 가능한 모델: GET https://cloud-api.near.ai/v1/models
# IRONCLAW_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# USE_REAL_TEE=true 로 설정하면 Mock 대신 IronClaw 실제 분석 사용
# 미설정 또는 false → Mock TEE (기본값)
# USE_REAL_TEE=true

# USE_REAL_ZKP=true 로 설정하면 IronClaw WASM 툴(zkp-prover) 호출로 proof 생성
# 미설정 또는 false → 로컬 HMAC-SHA256 commitment (기본값, 배포 안전)
# WASM 툴 등록 완료 후 true로 전환: zkp-prover-wasm/REGISTER.md 참조
# USE_REAL_ZKP=true
